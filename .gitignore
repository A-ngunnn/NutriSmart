# ==========================================
# NutriSmart - Master .gitignore (Full Stack)
# ==========================================

# Dependencies & Package Managers
**/node_modules/
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Next.js & Frontend Build Outputs
*/.next/
.next/
out/
dist/
/build
build/
.turbo/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
backend/error_log.txt

# Environment Variables & Secrets (คีย์ลับระบบ ห้ามเอาขึ้นเด็ดขาด)
.env
.env.local
.env.production
firebase-service-account*.json
**/firebase-service-account*.json
.env.development
.env*.local
**/.env*
backend/.env
frontend/.env.local

# Python Backend & Cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
ENV/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.bash_history
.python_history

# Database & Vector Database (ChromaDB Cache ตัวไฟล์หนัก)
**/chroma_data/
chroma_data/
.chroma/
*.db
*.sqlite3

# Editor & System Files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Vercel & Deployment
.vercel
*.tsbuildinfo

# Local backups
*.json.bak

# SUPABASE
.supabase