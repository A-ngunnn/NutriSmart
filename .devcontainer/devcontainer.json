{
  "name": "NutriSmart Dev Container",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  
  // 🟢 บรรทัดที่เพิ่มเข้ามา: สั่งให้ติดตั้ง Python พ่วงเข้าไปในตู้ Node.js ใบนี้ด้วย
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },

  "portsAttributes": {
    "3000": {
      "label": "Frontend",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    },
    "8000": {
      "label": "Backend",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  },
  "forwardPorts": [3000, 8000]
}